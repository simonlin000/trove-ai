# Trove AI environment configuration
# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit your real secrets.

# ── Database ─────────────────────────────────────────────
# Used by docker-compose. Change DB password before exposing to network.
POSTGRES_PASSWORD=change_me_to_a_strong_password

# ── JWT secret ───────────────────────────────────────────
# Used to sign login + sync tokens. CHANGE THIS in production —
# anyone with the secret can forge tokens for any user.
SECRET_KEY=change_me_to_a_random_secret_at_least_32_chars

# ── Optional: LLM / Embedding API keys (alternative to config_store.json) ──
# You can either set these here OR (preferred) configure via the web UI
# 设置 → AI 对话模型 / 嵌入模型. Web UI values are stored in config_store.json
# and take priority over these env vars.
#
# MINIMAX_API_KEY=
# SILICONFLOW_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# ── Optional: server-to-server service tokens ────────────
# Format: "tokenA:usernameA,tokenB:usernameB"
# Used by trusted internal callers (e.g. the wechat bot worker).
# Leave empty if you don't run wechat bot integration.
SERVICE_TOKENS=

# ── Optional: per-service tokens (referenced by wechat-bot etc.) ──
SERVICE_TOKEN_WECHAT_BOT=
